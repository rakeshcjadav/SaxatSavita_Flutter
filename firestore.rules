// Enhanced Firestore Security Rules with Admin Access
// Deploy these to Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'rakeshcjadav@gmail.com' ||
        request.auth.token.email == 'farenidham.dev@gmail.com' ||
        request.auth.token.email in ['admin1@example.com', 'admin2@example.com']
      );
    }
    
    // Admin access - allow admins to read all data
    match /{document=**} {
      allow read: if isAdmin();
    }
    
    // Users collection - regular users can read/write their own data, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to subcollections under user document
      match /{document=**} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // App settings - readable by authenticated users, writable by admins
    match /appSettings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Book user info - users can read/write their own, admins can read all
    match /bookUserInfo/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Kiran user info - users can read/write their own, admins can read all
    match /kiranUserInfo/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reading history - users can read/write their own, admins can read all
    match /readingHistory/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reading plans - users can read/write their own, admins can read all
    match /readingPlans/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Profile collection - users can read/write their own, admins can read all
    match /profile/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}